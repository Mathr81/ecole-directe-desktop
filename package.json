{
  "name": "ecole-directe-desktop",
  "productName": "Mon EcoleDirecte",
  "version": "1.4.6",
  "description": "Une application permettant de se connecter automatiquement à école directe",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:publish": "electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "Mathr81",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^25.6.2",
    "canvas": "^3.2.3",
    "cross-env": "^10.1.0",
    "electron-chrome-extensions": "^4.9.0",
    "electron-updater": "^6.3.9",
    "puppeteer-core": "^24.43.1",
    "puppeteer-in-electron": "^3.0.5"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "desktop.ecole-directe.app",
    "productName": "Mon EcoleDirecte",
    "publish": {
      "provider": "github",
      "owner": "Mathr81",
      "repo": "ecole-directe-desktop"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mon EcoleDirecte"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "category": "public.app-category.education",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Mon EcoleDirecte"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.png",
      "category": "Education",
      "maintainer": "Mathr81"
    },
    "files": [
      "**/*",
      "!userData/**",
      "!dist/**",
      "!.git/**"
    ],
    "extraFiles": [
      {
        "from": "CustomDirecte",
        "to": "CustomDirecte",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "CustomDirecte"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    }
  }
}